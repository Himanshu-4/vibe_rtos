# arch/Kconfig — Architecture selection

choice
    prompt "Target architecture"
    default ARCH_ARM

config ARCH_ARM
    bool "ARM"
    help
      ARM Cortex-M architecture (M0+, M33, M4, M55).
      Select the exact variant under "ARM Cortex-M variant".

endchoice

# Source the selected architecture's Kconfig
if ARCH_ARM
    source "arch/arm/Kconfig"
endif
