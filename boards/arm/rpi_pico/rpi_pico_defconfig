# Default Kconfig configuration for Raspberry Pi Pico (RP2040)
CONFIG_BOARD_RPI_PICO=y
CONFIG_SOC_RP2040=y
CONFIG_ARCH_ARM=y
CONFIG_CPU_CORTEX_M0PLUS=y

# System clock
CONFIG_SYS_CLOCK_HZ=1000

# Kernel features
CONFIG_KERNEL_PREEMPT_ENABLED=y
CONFIG_NUM_PRIORITIES=32
CONFIG_TIMESLICE_MS=10
CONFIG_TICKLESS_IDLE=y
CONFIG_SMP=n
CONFIG_HEAP_MEM=y
CONFIG_HEAP_SIZE=8192
CONFIG_STACK_CANARY=y
CONFIG_TLS=y
CONFIG_SCHED_DYNAMIC_PRIORITY=y

# Drivers
CONFIG_UART=y
CONFIG_GPIO=y
CONFIG_SPI=n
CONFIG_I2C=n
CONFIG_ADC=n
CONFIG_FLASH=n
CONFIG_TIMER_HW=n
CONFIG_RTC=n
CONFIG_WATCHDOG=n

# Subsystems
CONFIG_SHELL=y
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=2
CONFIG_LOG_BACKEND_UART=y
CONFIG_LOG_DEFERRED=n
